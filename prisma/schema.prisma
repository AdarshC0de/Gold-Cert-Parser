generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum JobStatus {
  PENDING
  PAUSED
  PROCESSING
  DONE
  FAILED
}

model User {
  id                 String          @id @default(cuid())
  name               String?
  email              String          @unique
  password           String
  role               Role            @default(USER)
  companyName        String?
  isActive           Boolean         @default(true)
  maxDevices         Int             @default(2)
  mustChangePassword Boolean         @default(false)
  documents          Document[]
  sessions           UserSession[]
  processingJobs     ProcessingJob[]
  createdAt          DateTime        @default(now())
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint String
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([userId, fingerprint])
}

model Document {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  fileUrl      String
  fileHash     String?
  refNumber    String?
  refDate      String?
  manufacturer String?
  origin       String?
  agent        String?
  invoiceNo    String?
  certNo       String?
  verified     Boolean       @default(false)
  rawOcrText   String?
  rows         DocumentRow[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@index([fileHash])
}

model DocumentRow {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  rowOrder   Int
  gram       String
  gramValue  Float?
  count      Int
  serialFrom Int
  serialTo   Int
  series     String
  purity     String?
  brand      String?

  @@index([gram, series, serialFrom, serialTo])
}

model ProcessingJob {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl    String
  fileName   String
  fileHash   String?
  status     JobStatus @default(PENDING)
  error      String?
  documentId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, status])
  @@index([status])
  @@index([fileHash])
}
